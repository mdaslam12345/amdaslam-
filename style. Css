/* ==========================================================================
   PREMIUM VARIABLES & RESET
   ========================================================================== */
:root {
    --bg-dark: #090d16;
    --card-bg: #131b2e;
    --neon-cyan: #00f2fe;
    --neon-purple: #4facfe;
    --text-main: #f1f5f9;
}

* { 
    margin: 0; 
    padding: 0; 
    box-sizing: border-box; 
}

body { 
    background-color: var(--bg-dark); 
    color: var(--text-main); 
    font-family: 'Rajdhani', sans-serif; 
    font-size: 1.2rem;
    scroll-behavior: smooth;
    overflow-x: hidden;
    position: relative;
}

/* ==========================================================================
   LIVE ANIMATED BACKGROUND EFFECT (Glow Pulsing)
   ========================================================================== */
body::before {
    content: '';
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: radial-gradient(circle at 20% 30%, rgba(79, 172, 254, 0.05) 0%, transparent 40%),
                radial-gradient(circle at 80% 70%, rgba(0, 242, 252, 0.05) 0%, transparent 40%);
    z-index: -1;
    animation: pulseBg 8s infinite alternate linear;
}

@keyframes pulseBg {
    0% { transform: scale(1); }
    100% { transform: scale(1.1); }
}

/* ==========================================================================
   PREMIUM GLASSMORPHISM NAVBAR
   ========================================================================== */
nav { 
    background: rgba(9, 13, 22, 0.8); 
    position: fixed; 
    width: 100%; 
    top: 0; 
    z-index: 1000; 
    padding: 20px 50px; 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    border-bottom: 1px solid rgba(0, 242, 254, 0.2); 
    backdrop-filter: blur(15px);
}

.logo { 
    font-family: 'Orbitron', sans-serif; 
    font-size: 1.6rem; 
    font-weight: 700; 
    background: linear-gradient(45deg, var(--neon-cyan), var(--neon-purple));
    -webkit-background-clip: text; 
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 15px rgba(0, 242, 254, 0.3);
}

.nav-links { 
    display: flex; 
    list-style: none; 
    gap: 30px; 
}

.nav-links a { 
    text-decoration: none; 
    color: #94a3b8; 
    font-weight: 700; 
    transition: 0.3s; 
    text-transform: uppercase; 
    letter-spacing: 1px; 
}

.nav-links a:hover { 
    color: var(--neon-cyan); 
    text-shadow: 0 0 10px var(--neon-cyan); 
}

/* ==========================================================================
   SECTIONS GENERAL STYLE
   ========================================================================== */
section { 
    padding: 120px 40px 80px; 
    max-width: 1200px; 
    margin: 0 auto; 
}

.section-title { 
    text-align: center; 
    font-family: 'Orbitron', sans-serif; 
    font-size: 2.8rem; 
    margin-bottom: 60px; 
    text-transform: uppercase; 
    letter-spacing: 2px;
    background: linear-gradient(180deg, #fff, #94a3b8); 
    -webkit-background-clip: text; 
    -webkit-text-fill-color: transparent;
}

/* ==========================================================================
   HOME HERO SECTION & GLOWING BUTTON
   ========================================================================== */
#home { 
    display: flex; 
    flex-direction: column; 
    justify-content: center; 
    align-items: center; 
    text-align: center; 
    min-height: 100vh; 
    position: relative; 
}

#home h1 { 
    font-family: 'Orbitron', sans-serif; 
    font-size: 4.5rem; 
    font-weight: 700; 
    margin-bottom: 15px; 
    text-transform: uppercase; 
    letter-spacing: 2px; 
}

#home h1 span { 
    background: linear-gradient(90deg, var(--neon-cyan), var(--neon-purple)); 
    -webkit-background-clip: text; 
    -webkit-text-fill-color: transparent; 
    filter: drop-shadow(0 0 20px rgba(0,242,254,0.4));
}

#home p { 
    font-size: 1.5rem; 
    color: #94a3b8; 
    max-width: 700px; 
    margin-bottom: 40px; 
    letter-spacing: 1px; 
}

.btn { 
    background: transparent; 
    color: #fff; 
    padding: 14px 40px; 
    border-radius: 5px; 
    font-weight: 700; 
    border: 2px solid var(--neon-cyan); 
    cursor: pointer; 
    text-transform: uppercase; 
    font-family: 'Orbitron', sans-serif;
    box-shadow: 0 0 15px rgba(0, 242, 254, 0.2); 
    transition: all 0.4s ease; 
    text-decoration: none;
}

.btn:hover { 
    background: var(--neon-cyan); 
    color: var(--bg-dark);
    box-shadow: 0 0 30px var(--neon-cyan); 
    transform: translateY(-3px);
}

/* ==========================================================================
   ABOUT SECTION (Glass Card)
   ========================================================================== */
.about-card {
    background: linear-gradient(135deg, rgba(19,27,46,0.7) 0%, rgba(9,13,22,0.8) 100%);
    border: 1px solid rgba(255,255,255,0.05); 
    padding: 40px; 
    border-radius: 15px;
    text-align: center; 
    max-width: 900px; 
    margin: 0 auto; 
    box-shadow: 0 20px 40px rgba(0,0,0,0.5);
}

.about-card p { 
    line-height: 1.8; 
    color: #cbd5e1; 
    font-size: 1.3rem; 
}

/* ==========================================================================
   ULTRA 3D FLASHCARDS (Flip Animation & Neon Shadow)
   ========================================================================== */
.flashcard-container { 
    display: grid; 
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); 
    gap: 40px; 
    margin-top: 20px; 
}

.card { 
    height: 320px; 
    perspective: 1200px; 
}

.card-inner { 
    position: relative; 
    width: 100%; 
    height: 100%; 
    text-align: center; 
    transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
    transform-style: preserve-3d; 
}

/* Hover ya Tap karne par card flip hoga */
.card:hover .card-inner { 
    transform: rotateY(180deg); 
}

.card-front, .card-back { 
    position: absolute; 
    width: 100%; 
    height: 100%; 
    -webkit-backface-visibility: hidden; 
    backface-visibility: hidden; 
    border-radius: 20px; 
    display: flex; 
    flex-direction: column; 
    justify-content: center; 
    align-items: center; 
    padding: 30px; 
    box-shadow: 0 15px 35px rgba(0,0,0,0.5);
}

.card-front { 
    background: var(--card-bg); 
    border: 1px solid rgba(0, 242, 254, 0.15); 
    color: var(--neon-cyan); 
    font-family: 'Orbitron', sans-serif; 
    font-size: 1.6rem; 
    font-weight: 700;
}

.card-front .icon { 
    font-size: 4rem; 
    margin-bottom: 20px; 
    filter: drop-shadow(0 0 15px var(--neon-cyan)); 
}

.card-back { 
    background: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%); 
    color: white; 
    transform: rotateY(180deg); 
    font-size: 1.2rem; 
    line-height: 1.6;
    border: 2px solid var(--neon-purple); 
    box-shadow: 0 0 25px rgba(79, 172, 254, 0.4);
}

.card-back h3 { 
    font-family: 'Orbitron', sans-serif; 
    margin-bottom: 15px; 
    color: var(--neon-cyan); 
}

/* ==========================================================================
   FEATURED PROJECTS
   ========================================================================== */
.projects-grid { 
    display: grid; 
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); 
    gap: 30px; 
}

.project-card { 
    background: var(--card-bg); 
    border-radius: 15px; 
    padding: 35px; 
    border: 1px solid rgba(255,255,255,0.03); 
    position: relative; 
    overflow: hidden; 
    transition: all 0.4s ease;
}

/* Top line loading effect on hover */
.project-card::before {
    content: ''; 
    position: absolute; 
    top: 0; left: 0; width: 100%; height: 3px;
    background: linear-gradient(90deg, var(--neon-cyan), var(--neon-purple));
    transform: scaleX(0); 
    transition: transform 0.4s ease; 
    transform-origin: left;
}

.project-card:hover { 
    transform: translateY(-8px); 
    box-shadow: 0 15px 30px rgba(0,0,0,0.6); 
    border-color: rgba(0, 242, 254, 0.2); 
}

.project-card:hover::before { 
    transform: scaleX(1); 
}

.project-card h3 { 
    color: #fff; 
    font-family: 'Orbitron', sans-serif; 
    margin-bottom: 15px; 
    font-size: 1.4rem; 
}

.project-card p { 
    color: #94a3b8; 
    font-size: 1.1rem; 
    line-height: 1.6; 
}

/* ==========================================================================
   CONTACT BOX & FOOTER
   ========================================================================== */
.contact-box { 
    background: var(--card-bg); 
    padding: 40px; 
    border-radius: 15px; 
    display: inline-block; 
    border: 1px solid rgba(79, 172, 254, 0.1); 
}

.contact-info { 
    margin-top: 10px; 
    display: flex; 
    flex-direction: column; 
    gap: 15px; 
    font-size: 1.3rem; 
}

.contact-info span { 
    color: var(--neon-cyan); 
    font-weight: 700; 
    font-family: 'Orbitron', sans-serif; 
}

footer { 
    border-top: 1px solid rgba(255,255,255,0.05); 
    text-align: center; 
    padding: 40px; 
    margin-top: 80px; 
    color: #475569; 
    font-size: 1rem; 
    font-family: 'Orbitron', sans-serif; 
}

/* ==========================================================================
   RESPONSIVE DESIGN (For Mobile Phones)
   ========================================================================== */
@media (max-width: 768px) {
    nav { 
        padding: 15px; 
        flex-direction: column; 
        gap: 10px; 
    }
    #home h1 { 
        font-size: 2.8rem; 
    }
    .section-title { 
        font-size: 2rem; 
    }
    section { 
        padding: 100px 20px 40px; 
    }
}
